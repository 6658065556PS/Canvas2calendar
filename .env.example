# Canvas2Calendar — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ── Google OAuth (configured inside Supabase, not here directly) ──────────────
# In Supabase Dashboard → Authentication → Providers → Google:
#   1. Enable Google provider
#   2. Set Client ID and Client Secret (from Google Cloud Console)
#   3. Add OAuth scopes:  openid email profile https://www.googleapis.com/auth/calendar
#   4. Add redirect URL to Google Cloud Console:
#      https://your-project-id.supabase.co/auth/v1/callback
#
# In Google Cloud Console → APIs & Services → OAuth consent screen:
#   Add scope: https://www.googleapis.com/auth/calendar.events
#
# The redirect URL for your LOCAL dev site (add to Supabase allowed redirects):
#   http://localhost:5173/auth/callback
